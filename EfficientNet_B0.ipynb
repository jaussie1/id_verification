# ==========================================
# 1. SETUP & IMPORTS
# ==========================================
import torch
import torch.nn as nn
import torch.optim as optim
import numpy as np
from torchvision import datasets, transforms
from torchvision.models import efficientnet_b0, EfficientNet_B0_Weights
from torch.utils.data import DataLoader, Subset
from sklearn.model_selection import train_test_split
from sklearn.metrics import confusion_matrix, classification_report
import matplotlib.pyplot as plt
import seaborn as sns
import time
import copy
import os
from google.colab import drive

# Mount Google Drive
if not os.path.exists('/content/drive'):
    drive.mount('/content/drive')

# ==========================================
# 2. CONFIGURATION
# ==========================================
DATA_PATH = '/content/drive/MyDrive/ID_Dataset'

BATCH_SIZE = 16
NUM_EPOCHS = 15
LEARNING_RATE = 0.0005 # EfficientNet prefers a lower LR

# Set Device (GPU)
device = torch.device("cuda:0" if torch.cuda.is_available() else "cpu")
print(f"Training on device: {device}")

# ==========================================
# 3. DATA PROCESSING
# ==========================================
# Transforms: Resize, Fix PNGs, Augment Training Data
data_transforms = {
    'train': transforms.Compose([
        # Remove alpha channel if present
        transforms.Lambda(lambda x: x.convert('RGB')), 
        # EfficientNet-B0 standard size
        transforms.Resize((224, 224)), 
        # 50% chance to flip horizontally
        transforms.RandomHorizontalFlip(), 
        # Rotate up to 15 degrees for tilted shots
        transforms.RandomRotation(15), 
        # Vary lighting/color (brightness, contrast, saturation, hue)
        transforms.ColorJitter(brightness=0.3, contrast=0.3, saturation=0.2, hue=0.05), 
        # 50% chance to tilt/skew
        transforms.RandomPerspective(distortion_scale=0.2, p=0.5), 
        # Convert PIL image to PyTorch tensor
        transforms.ToTensor(), 
        # Standardize using ImageNet stats
        transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]) 
    ]),
    'val': transforms.Compose([
        transforms.Lambda(lambda x: x.convert('RGB')),
        transforms.Resize((224, 224)),
        transforms.ToTensor(),
        transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])
    ]),
}

# Custom Wrapper
class SubsetWrapper(torch.utils.data.Dataset):
    def __init__(self, subset, transform=None):
        self.subset = subset
        self.transform = transform
    def __getitem__(self, index):
        x, y = self.subset[index]
        if self.transform: x = self.transform(x)
        return x, y
    def __len__(self): return len(self.subset)

print("Loading dataset...")
full_dataset = datasets.ImageFolder(DATA_PATH)
classes = full_dataset.classes # Should be ['Fake', 'Real']
print(f"Classes found: {classes}")

# Stratified Split (80% Train / 20% Val)
train_idx, val_idx = train_test_split(
    np.arange(len(full_dataset)),
    test_size=0.2,
    shuffle=True,
    stratify=full_dataset.targets,
    random_state=42
)

train_dataset = SubsetWrapper(Subset(full_dataset, train_idx), data_transforms['train'])
val_dataset = SubsetWrapper(Subset(full_dataset, val_idx), data_transforms['val'])

dataloaders = {
    'train': DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True, num_workers=2),
    'val': DataLoader(val_dataset, batch_size=BATCH_SIZE, shuffle=False, num_workers=2)
}
dataset_sizes = {'train': len(train_dataset), 'val': len(val_dataset)}

# ==========================================
# 4. MODEL SETUP (EFFICIENTNET-B0)
# ==========================================
print("Initializing EfficientNet-B0...")

# Load Pre-trained Weights (ImageNet)
weights = EfficientNet_B0_Weights.IMAGENET1K_V1
model = efficientnet_b0(weights=weights)

# Freeze the "Feature Extractor" (Body)
for param in model.features.parameters():
    param.requires_grad = False

# Replace the "Classifier" (Head)
# classifier[1] is the final linear layer
num_ftrs = model.classifier[1].in_features
model.classifier[1] = nn.Linear(num_ftrs, 2) # 2 Classes: Fake vs Real

model = model.to(device)

criterion = nn.CrossEntropyLoss()
# Use Adam optimizer because it is the state-of-the-art for fine-tuning
optimizer = optim.Adam(model.parameters(), lr=LEARNING_RATE)

# ==========================================
# 5. TRAINING LOOP
# ==========================================
def train_model(model, criterion, optimizer, num_epochs=15):
    since = time.time()
    # Save the initial weights as the "best" to start with
    best_model_wts = copy.deepcopy(model.state_dict())
    best_acc = 0.0

    train_acc_history = []
    val_acc_history = []

    for epoch in range(num_epochs):
        print(f'Epoch {epoch+1}/{num_epochs}')
        print('-' * 10)

        for phase in ['train', 'val']:
            # Toggle dropout/batchnorm layers based on the current phase
            if phase == 'train': model.train()
            else: model.eval()

            running_loss = 0.0
            running_corrects = 0

            for inputs, labels in dataloaders[phase]:
                inputs = inputs.to(device)
                labels = labels.to(device)

                # Reset gradients to zero so they don't accumulate from the last batch
                optimizer.zero_grad()

                # Disable gradient calculation during validation to save memory/speed
                with torch.set_grad_enabled(phase == 'train'):
                    outputs = model(inputs)
                    _, preds = torch.max(outputs, 1)
                    loss = criterion(outputs, labels)

                    # Only update weights if we are in the training phase
                    if phase == 'train':
                        loss.backward()
                        optimizer.step()

                # Accumulate loss and accuracy for the whole epoch
                running_loss += loss.item() * inputs.size(0)
                running_corrects += torch.sum(preds == labels.data)

            epoch_loss = running_loss / dataset_sizes[phase]
            epoch_acc = running_corrects.double() / dataset_sizes[phase]

            print(f'{phase} Loss: {epoch_loss:.4f} Acc: {epoch_acc:.4f}')

            # If this version of the model is the most accurate so far, save it
            if phase == 'val' and epoch_acc > best_acc:
                best_acc = epoch_acc
                best_model_wts = copy.deepcopy(model.state_dict())

            # Store history for later plotting or analysis
            if phase == 'train': train_acc_history.append(epoch_acc.cpu())
            else: val_acc_history.append(epoch_acc.cpu())

        print()

    time_elapsed = time.time() - since
    print(f'Training complete in {time_elapsed // 60:.0f}m {time_elapsed % 60:.0f}s')
    print(f'Best val Acc: {best_acc:.4f}')

    # Return the model in its "best performing" state rather than its "most recent" state
    model.load_state_dict(best_model_wts)
    return model, train_acc_history, val_acc_history

# Execute training
trained_model, t_hist, v_hist = train_model(model, criterion, optimizer, num_epochs=NUM_EPOCHS)

# ==========================================
# 6. EVALUATION (Metrics & Confusion Matrix)
# ==========================================
def evaluate_metrics(model, loader):
    model.eval()
    all_labels = []
    all_preds = []

    print("\nRunning Detailed Evaluation...")
    with torch.no_grad():
        for inputs, labels in loader:
            inputs = inputs.to(device)
            labels = labels.to(device)
            outputs = model(inputs)
            _, preds = torch.max(outputs, 1)
            all_labels.extend(labels.cpu().numpy())
            all_preds.extend(preds.cpu().numpy())

    report = classification_report(all_labels, all_preds, target_names=['Fake', 'Real'], digits=4)

    print("\n" + "="*60)
    print("CLASSIFICATION REPORT:")
    print("="*60)
    print(report)
    print("-" * 60)

    # Confusion Matrix
    cm = confusion_matrix(all_labels, all_preds)

    # Plot Confusion Matrix
    plt.figure(figsize=(6, 5))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                xticklabels=['Fake', 'Real'],
                yticklabels=['Fake', 'Real'])
    plt.ylabel('Actual')
    plt.xlabel('Predicted')
    plt.title('Confusion Matrix (EfficientNet-B0)')
    plt.show()

evaluate_metrics(trained_model, dataloaders['val'])

# ==========================================
# 7. SAVE MODEL
# ==========================================
torch.save(trained_model, 'efficientnet_b0_id_verification.pth')
print("Model saved as 'efficientnet_b0_id_verification.pth'")
